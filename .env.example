APP_ENV=development
DEBUG=false

DATABASE_URL=postgresql+psycopg://geoautomap:geoautomap@localhost:5432/geoautomap
ALEMBIC_DATABASE_URL=postgresql+psycopg://geoautomap:geoautomap@localhost:5432/geoautomap

API_PREFIX=/api
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

CORS_ORIGINS=http://localhost:5173,http://localhost:8080

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_SEC=30
LLM_MAX_RETRIES=2
ENABLE_MOCK_LLM=true

NOMINATIM_ENABLED=false
NOMINATIM_URL=https://nominatim.openstreetmap.org/search

MAX_UPLOAD_SIZE_MB=15
CHUNK_SIZE_CHARS=1800
CHUNK_OVERLAP_CHARS=200

UPLOAD_DIR=./data/uploads
EXPORT_DIR=./sample_data/outputs

VITE_API_BASE_URL=http://localhost:8000
